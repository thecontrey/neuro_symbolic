{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Schema-constrained LLM extraction output",
  "type": "object",
  "required": [
    "facts",
    "rules",
    "priorities"
  ],
  "properties": {
    "facts": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "priorities": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "confidence": {
      "type": "number"
    },
    "source_pointers": {
      "type": "array"
    }
  }
}